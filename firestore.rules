rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/data/{dataId}
    // Document ID: {dataId} (e.g., 'storyRules', 'page1_state')
    // Fields:
    //   - sync_id: string (required) - ID đồng bộ của người dùng
    //   - key: string (required) - Khóa dữ liệu
    //   - value: string (required) - Giá trị dữ liệu (JSON string)
    //   - updated_at: timestamp (optional) - Thời gian cập nhật
    //
    // Collection: /shared_stories/{slug}
    // Document ID: {slug} (random string)
    // Fields:
    //   - slug: string (required) - Slug định danh truyện
    //   - title: string (required) - Tiêu đề truyện
    //   - content: string (required) - Nội dung truyện (JSON string)
    //   - author_uid: string (required) - UID của tác giả
    //   - created_at: timestamp (optional) - Thời gian tạo
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "dpa241200@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('author_uid' in request.resource.data) ||
        request.resource.data.author_uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('author_uid' in request.resource.data) ||
        request.resource.data.author_uid == resource.data.author_uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUserData(data) {
      return data.sync_id is string && data.sync_id.size() < 100 &&
             data.key is string && data.key.size() < 100 &&
             data.value is string && data.value.size() < 1048576; // 1MB limit per field
    }

    function isValidSharedStory(data) {
      return data.slug is string && data.slug.size() < 100 &&
             data.title is string && data.title.size() < 500 &&
             data.content is string && data.content.size() < 1048576 &&
             data.author_uid is string && data.author_uid.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User data is private to the user
    match /users/{userId}/data/{dataId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      hasRequiredFields(['sync_id', 'key', 'value']) && 
                      isValidUserData(request.resource.data);
      allow update: if isOwner(userId) && 
                      isValidUserData(request.resource.data);
      allow delete: if isOwner(userId);
    }

    // Shared stories are public for reading, but only author can create/update/delete
    match /shared_stories/{slug} {
      allow read: if true; // Public access for shared stories
      allow create: if isAuthenticated() && 
                      hasRequiredFields(['slug', 'title', 'content', 'author_uid']) && 
                      isValidSharedStory(request.resource.data) &&
                      request.resource.data.author_uid == request.auth.uid;
      allow update: if isAuthenticated() && 
                      (request.auth.uid == resource.data.author_uid || isAdmin()) &&
                      isValidSharedStory(request.resource.data) &&
                      uidNotModified();
      allow delete: if isAuthenticated() && 
                      (request.auth.uid == resource.data.author_uid || isAdmin());
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
