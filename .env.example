# ============ BẮT BUỘC (cần ít nhất 1 trong 2) ============
# Gemini API Key — lấy từ https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# DeepSeek API Key — lấy từ https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ============ FIREBASE CONFIG (bắt buộc) ============
# Lấy từ: Firebase Console > Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=(default)
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
